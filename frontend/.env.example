# These variables are only available to the Nuxt development server and build step!
# See backend/.env for Craft’s environment variables.

SITE_NAME=Nuxt Starter
ENV=dev
BASE_URL=https://starter-nuxt.ddev.site
CRAFT_URL=https://api.starter-nuxt.ddev.site
GRAPHQL_TOKEN=

# Optional. Must match the LLMify "API Token" configured in Craft.
# Sent to the LLMify API as the X-Llmify-Token header. Leave empty if unprotected.
LLMIFY_API_TOKEN=
